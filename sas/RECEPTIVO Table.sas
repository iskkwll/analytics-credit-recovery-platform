%mensagem(3.2.3 ordena tabela Auxiliar);
PROC SORT DATA= AUXILIAR_DIARIO; BY DCONCATENADO DESCENDING PERC_DIV;

%mensagem(3.2.4 Aplica regra de posicao);
DATA AUXILIAR_DIARIO;
SET AUXILIAR_DIARIO;
BY DCONCATENADO;
IF first.DCONCATENADO then Posicao = 1;
ELSE Posicao + 1;
