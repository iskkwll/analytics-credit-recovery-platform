
%macro B2C_Consolidar_Tabelas;

%mensagem(1. Gera Tabela RECUPERA_OPERACAO);
DATA RECUPERA_OPERACAO_DIARIO;
SET 
	TT.OPERACAO_&safra_final2. (&COLUMN3_B2C.)
	TT.OPERACAO_&safra_final1. (&COLUMN3_B2C.)
	;
	SAFRA = (YEAR(data_base)*100) + MONTH(data_base);
	DIA = DAY(data_base);
	MES = MONTH(data_base);

	IF flag_categoria_b_passivel = 1 THEN CLASS = 'PASSIVEL';
	ELSE IF flag_categoria_b_previa = 1 THEN CLASS = 'PREVIA';
	ELSE CLASS = 'NULL';

	FORMAT DIVIDA_ANTES 	8.2;
	FORMAT DIVIDA_DEPOIS	8.2;

	DIVIDA_ANTES = 	
	COALESCE(divida_CATEGORIA_A_SISTEMA_A,0) + 
	COALESCE(divida_CATEGORIA_B_SISTEMA_A,0) + 
	COALESCE(divida_CATEGORIA_B_SISTEMA_B,0) + 
	COALESCE(divida_CATEGORIA_C_SISTEMA_A,0) + 
	COALESCE(divida_CATEGORIA_C_SISTEMA_C,0);

	DIVIDA_DEPOIS = 
	COALESCE(divida_apos_CATEGORIA_A_SISTEMA_A,0) +
	COALESCE(divida_apos_CATEGORIA_B_SISTEMA_A,0) + 
	COALESCE(divida_apos_CATEGORIA_B_SISTEMA_B,0) + 
	COALESCE(divida_apos_CATEGORIA_C_SISTEMA_A,0) + 
	COALESCE(divida_apos_CATEGORIA_C_SISTEMA_C,0); 

	ACORDOS = 
	MAX(
	COALESCE(fl_acordo_sistema_c,0), 
	COALESCE(fl_acordo_sistema_b,0), 
	COALESCE(fl_acordo_sistema_a_s_log,0), 
	COALESCE(fl_acordo_sistema_a,0)
	);

	QUEBRAS = 
	MAX(
	COALESCE(fl_quebra_acordo_sisA_catA,0) , 
	COALESCE(fl_quebra_acordo_sisA_catB,0) , 
	COALESCE(fl_quebra_acordo_sisA_catC,0) ,
	COALESCE(fl_quebra_acordo_sistema_c,0) , 
	COALESCE(fl_quebra_acordo_sistema_b,0) ,
	COALESCE(fl_quebra_acordo_sisA_catA_s_log,0) ,
	COALESCE(fl_quebra_acordo_sisA_catB_s_log,0) ,
	COALESCE(fl_quebra_acordo_sisA_catC_s_log,0)
	);

	aging_max_apos_total =  	
	COALESCE(aging_max_apos_CATEGORIA_A_AMDOC,0) + 
	COALESCE(aging_max_apos_CATEGORIA_B_SISTEMA_A,0) +
	COALESCE(aging_max_apos_CATEGORIA_B_SISTEMA_B,0) + 
	COALESCE(aging_max_apos_CATEGORIA_C_SISTEMA_A,0) + 	
	COALESCE(aging_max_apos_CATEGORIA_C_SISTEMA_C,0);
	
	aging_max_total =  	
	COALESCE(aging_max_CATEGORIA_A_SISTEMA_A,0) + 	
	COALESCE(aging_max_CATEGORIA_B_SISTEMA_A,0) + 
	COALESCE(aging_max_CATEGORIA_B_SISTEMA_B,0) +
	COALESCE(aging_max_CATEGORIA_C_SISTEMA_A,0) + 
	COALESCE(aging_max_CATEGORIA_C_SISTEMA_C,0);
	
	aging = max(
	COALESCE(aging_max_CATEGORIA_A_SISTEMA_A,0),
	COALESCE(aging_max_CATEGORIA_B_SISTEMA_A,0),
	COALESCE(aging_max_CATEGORIA_B_SISTEMA_B,0),
	COALESCE(aging_max_CATEGORIA_C_SISTEMA_A,0),
	COALESCE(aging_max_CATEGORIA_C_SISTEMA_C,0)
	);
RUN;

%mensagem(2. Aplica regras a TB RECUPERA_OPERACAO);
DATA RECUPERA_OPERACAO_DIARIO;
SET RECUPERA_OPERACAO_DIARIO;

	IF (
	COALESCE(divida_CATEGORIA_A_SISTEMA_A,0) + 
	COALESCE(divida_CATEGORIA_B_SISTEMA_A,0) + 
	COALESCE(divida_CATEGORIA_B_SISTEMA_B,0) + 
	COALESCE(divida_CATEGORIA_C_SISTEMA_A,0) + 		
	COALESCE(divida_CATEGORIA_C_SISTEMA_C,0)
	) 
	NE 0 THEN POSSUI_DIVIDA = 1; ELSE POSSUI_DIVIDA = 0;

	IF COALESCE(aging_max_apos_total,0) < COALESCE(aging_max_total,0) 
	AND DIVIDA_DEPOIS < DIVIDA_ANTES 
	AND DIVIDA_DEPOIS NE 0 
	AND DIVIDA_ANTES NE 0
	THEN AGING_REDUZIDO = 1; ELSE AGING_REDUZIDO = 0;

	IF DIVIDA_ANTES > DIVIDA_DEPOIS	
	AND DIVIDA_DEPOIS NE 0 
	AND COALESCE(aging_max_apos_total,0) >= COALESCE(aging_max_total,0) 
	THEN DIVIDA_REDUZIDA = 1; ELSE DIVIDA_REDUZIDA = 0;
	
	IF DIVIDA_ANTES NE 0 
	AND DIVIDA_ANTES > DIVIDA_DEPOIS 
	AND COALESCE(aging_max_apos_total,0) < COALESCE(aging_max_total,0)
	THEN DIVIDA_PAGA = 1; ELSE DIVIDA_PAGA = 0;

	IF DIVIDA_ANTES NE 0 
	AND DIVIDA_ANTES <= DIVIDA_DEPOIS 
	AND COALESCE(aging_max_apos_total,0) > COALESCE(aging_max_total,0)
	THEN DIVIDA_NAO_PAGA = 1; ELSE DIVIDA_NAO_PAGA = 0;
	
	IF POSSUI_DIVIDA = 0 THEN ACORDOS = 0; ELSE ACORDOS = ACORDOS;
	
	DCONCATENADO =  CATX('',SAFRA,GRUPO_ATENDIMENTO,DIA);
	MCONCATENADO =  CATX('',SAFRA,GRUPO_ATENDIMENTO);
	
	IF 		0	<=aging	<10 	then CARTEIRA_ENTRADA = 'M0';
	ELSE IF 10	<=aging	<31 	then CARTEIRA_ENTRADA = 'M1';
	ELSE IF 31	<=aging	<51 	then CARTEIRA_ENTRADA = 'M2';
	ELSE IF 51	<=aging	<91 	then CARTEIRA_ENTRADA = 'M3';
	ELSE IF 91	<=aging	<121 	then CARTEIRA_ENTRADA = 'M4';
	ELSE IF 121	<=aging	<271 	then CARTEIRA_ENTRADA = 'F0';
	ELSE IF 271	<=aging	<361 	then CARTEIRA_ENTRADA = 'F1';
	ELSE IF 361	<=aging	<721 	then CARTEIRA_ENTRADA = 'F2';
	ELSE IF 721	<=aging	<1081 	then CARTEIRA_ENTRADA = 'F3';
	ELSE IF 1081<=aging	<1441 	then CARTEIRA_ENTRADA = 'F4';
	ELSE IF 1441<=aging	<1801 	then CARTEIRA_ENTRADA = 'F5';
	ELSE IF 1801<=aging	<2161 	then CARTEIRA_ENTRADA = 'F6';
	ELSE IF 2161<=aging	<2521 	then CARTEIRA_ENTRADA = 'F7';
	ELSE IF 2521<=aging	<2881 	then CARTEIRA_ENTRADA = 'F8';
	ELSE IF 2881<=aging	<3241 	then CARTEIRA_ENTRADA = 'F9';
	ELSE IF 3241<=aging 		then CARTEIRA_ENTRADA = 'F10';
	ELSE CARTEIRA_ENTRADA = 'NAO ENCONTRADO';
	
	IF DIVIDA_REDUZIDA = 1 THEN DIVIDA_ANTES_S_RED = 0;
	ELSE DIVIDA_ANTES_S_RED = DIVIDA_ANTES;
	
	IF DIVIDA_REDUZIDA = 1 THEN DIVIDA_DEPOIS_S_RED = 0;
	ELSE DIVIDA_DEPOIS_S_RED = DIVIDA_DEPOIS;
RUN;

DATA OPERACAO_DIARIO;
SET WORK.OPERACAO_DIARIO(&COLMNFIN_B2C.);


%mensagem(3. Ordena Tabela e gera Tabela Unique);
PROC SORT DATA= RECUPERA_OPERACAO_DIARIO; BY DOCUMENTO descending data_base DESCENDING DIVIDA_PAGA DESCENDING DIVIDA_REDUZIDA;
PROC SORT DATA= RECUPERA_OPERACAO_DIARIO Out=RECUPERA_OPERACAO_DIARIO_UNI Nodupkey; BY DOCUMENTO GRUPO_ATENDIMENTO SAFRA;

%mend;

%macro B2C_Aplica_regra_Unique_Diario;

%mensagem(3.1. Aplica regra de Diario - Unique);

%mensagem(3.1.1 Cria regra de maturacao);
PROC SQL;
CREATE TABLE RECUPERA_OP_DIA_MATU_UNIQUE AS 
SELECT *
,CASE 
	WHEN data_base <= (SELECT MAX(data_base)-13 FROM RECUPERA_OPERACAO_DIARIO_UNI) 
	THEN "SIM" ELSE "NÃO" END AS MATURADO 
FROM (
	SELECT * FROM RECUPERA_OPERACAO_DIARIO_UNI 
	WHERE data_base <= (SELECT MAX(data_base)
						FROM RECUPERA_OPERACAO_DIARIO_UNI WHERE DIVIDA_DEPOIS > 0)) AS A 
ORDER BY data_base
;QUIT;

%mensagem(3.1.2 Gera tabela auxiliar);
PROC SQL;
CREATE TABLE AUXILIAR_DIARIO_UNIQUE AS 
SELECT 
SAFRA 
,DCONCATENADO
,USERNAME 
,SUM(POSSUI_DIVIDA) AS POSSUI_DIVIDA
,SUM(DIVIDA_PAGA) / SUM(POSSUI_DIVIDA) AS PERC_DIV
FROM RECUPERA_OP_DIA_MATU_UNIQUE A 
GROUP BY 1,2,3
;QUIT;

%mensagem(3.1.3 Ordena tabela auxiliar);
PROC SORT DATA= AUXILIAR_DIARIO_UNIQUE; BY DCONCATENADO DESCENDING PERC_DIV;

%mensagem(3.1.4 Aplica regra de posicao);
DATA AUXILIAR_DIARIO_UNIQUE;
SET AUXILIAR_DIARIO_UNIQUE;
BY DCONCATENADO;
IF first.DCONCATENADO then Posicao = 1;
ELSE Posicao + 1;
RUN;

%mensagem(3.1.5 Gera tabela auxiliar TAS);
PROC SQL;
CREATE TABLE TAS_DIARIO_UNIQUE AS 
SELECT 
SAFRA 
,DCONCATENADO
,USERNAME
,CATX('',USERNAME,DCONCATENADO) AS ID
,POSSUI_DIVIDA
,Posicao	
,(Posicao/(SELECT QTD 
			FROM (
				SELECT DCONCATENADO ,COUNT(DCONCATENADO) AS QTD 
				FROM AUXILIAR_DIARIO_UNIQUE GROUP BY 1) AS B 
			WHERE A.DCONCATENADO = B.DCONCATENADO)) AS Percentual
FROM AUXILIAR_DIARIO_UNIQUE A
;QUIT;

%mend;
