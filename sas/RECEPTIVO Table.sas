%mensagem(3.2.5 Cria tabela auxiliar TAS);
PROC SQL;
CREATE TABLE TAS_DIARIO AS 
SELECT 
SAFRA 
, DCONCATENADO
, USERNAME
, CATX('',USERNAME,DCONCATENADO) AS ID
, POSSUI_DIVIDA
, Posicao	
