			FROM (
				SELECT DCONCATENADO ,COUNT(DCONCATENADO) AS QTD 
				FROM AUXILIAR_DIARIO GROUP BY 1) AS B 
			WHERE A.DCONCATENADO = B.DCONCATENADO)) AS Percentual
